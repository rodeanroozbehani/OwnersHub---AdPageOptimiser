# Copy this file to `.env` and fill in real values.
# After creating `.env`, on Linux: chmod 600 .env

# Anthropic API key for Claude (required)
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key for Henry's approval emails (required for HITL)
RESEND_API_KEY=re_...

# Optional: override the default config path
# ADS_OPTIMIZER_CONFIG=/absolute/path/to/config.yaml
