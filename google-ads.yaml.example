# google-ads.yaml — credentials template
#
# 1. Copy this file to `google-ads.yaml` (same directory)
# 2. Fill in all four required fields (run tools/oauth_bootstrap.py for the tokens)
# 3. On Linux: chmod 600 google-ads.yaml
# 4. Never commit google-ads.yaml to git (it is in .gitignore)
#
# Where to get each value:
#   developer_token  — Google Ads Manager Account → Tools → API Centre
#                      "Basic access" is sufficient for read-only reporting
#   client_id /
#   client_secret    — Google Cloud Console → APIs & Services → Credentials
#                      Create an OAuth 2.0 Client ID (Desktop app type)
#   refresh_token    — run: python tools/oauth_bootstrap.py --client-secrets client_secret.json
#   login_customer_id — your Manager (MCC) account id without dashes (optional;
#                       only needed if accessing a sub-account via a manager)

developer_token: "YOUR_DEVELOPER_TOKEN"
client_id: "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret: "YOUR_CLIENT_SECRET"
refresh_token: "YOUR_REFRESH_TOKEN"
# login_customer_id: "1234567890"
use_proto_plus: true
